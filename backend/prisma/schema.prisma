// Banco: PostgreSQL (Supabase/Railway)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  clients   Client[]
  activities Activity[]
  featurePermissions TenantFeaturePermission[]
  portalSections PortalSection[]
  portalItems    PortalItem[]
  portalEvents   PortalEvent[]
  emailNotificationRules TenantEmailNotificationRule[]
  kanbanColumns KanbanColumn[]
  holidays  TenantHoliday[]
}

model TenantFeaturePermission {
  id        String   @id @default(cuid())
  tenantId  String
  featureId String
  role      String
  state     String   @default("allow") // allow | deny
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureId, role])
  @@index([tenantId, role])
  @@map("tenant_feature_permissions")
}

/// Regras de e-mail por tipo de projeto (TipoProjeto) e gatilho (CRIACAO, STATUS_CHANGE, ...).
model TenantEmailNotificationRule {
  id          String   @id @default(cuid())
  tenantId    String
  projectType String
  trigger     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, projectType, trigger], map: "ten_email_rules_tpt_trig_uq")
  @@index([tenantId], map: "ten_email_rules_tenant_idx")
  @@map("tenant_email_notification_rules")
}

model User {
  id                    String   @id @default(cuid())
  email                 String
  name                  String
  passwordHash          String
  role                  String
  tenantId              String
  cargo                 String?
  avatarUrl             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  cargaHorariaSemanal   Float?   @default(40)
  limiteHorasDiarias    Float?   @default(8)
  /// JSON com horas permitidas por dia: { "dom": 0, "seg": 8, ... }
  limiteHorasPorDia     String?
  permitirMaisHoras     Boolean  @default(false)
  permitirFimDeSemana   Boolean  @default(false)
  permitirOutroPeriodo  Boolean  @default(false)
  diasPermitidos        String?
  dataInicioAtividades  DateTime?
  birthDate             DateTime?
  mustChangePassword    Boolean  @default(true)
  ativo                 Boolean  @default(true)
  inativadoEm           DateTime?
  inativacaoMotivo      String?

  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdProjects       Project[]     @relation("ProjectCreator")
  timeEntries           TimeEntry[]
  assignedTickets       Ticket[]      @relation("AssignedConsultant")
  createdTickets        Ticket[]      @relation("TicketCreator")
  ticketResponsibles    TicketResponsible[]
  ticketComments        TicketComment[]
  ticketHistory         TicketHistory[] @relation("TicketHistoryUser")
  ticketAttachments     TicketAttachment[] @relation("TicketAttachmentUser")
  ticketBudgetsSent     TicketBudget[] @relation("TicketBudgetSentBy")
  ticketBudgetsDecided  TicketBudget[] @relation("TicketBudgetDecidedBy")
  passwordResetTokens   PasswordResetToken[]
  hourBankRecords       HourBankRecord[]
  clientAccess          ClientUser[]  @relation("ClientUser")
  projectResponsibles  ProjectResponsible[]  @relation("ProjectResponsible")
  timeEntryPermissionRequests TimeEntryPermissionRequest[] @relation("TimeEntryPermissionRequestUser")
  @@unique([email, tenantId])
  @@index([tenantId, name])
  @@map("users")
}

model PortalSection {
  id        String   @id @default(cuid())
  tenantId  String
  title     String
  slug      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     PortalItem[]

  @@unique([tenantId, slug])
  @@index([tenantId, order])
}

model PortalItem {
  id        String   @id @default(cuid())
  tenantId  String
  sectionId String
  title     String
  content   String
  type      String
  metadata  Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  section   PortalSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([tenantId, sectionId])
}

model PortalEvent {
  id        String   @id @default(cuid())
  tenantId  String
  title     String
  description String?
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, date])
}

model Client {
  id        String   @id @default(cuid())
  name      String
  tenantId  String
  email     String?
  cnpj      String?
  telefone  String?
  cep       String?
  endereco  String?
  numero    String?
  complemento String?
  bairro    String?
  cidade    String?
  estado    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects  Project[]
  users     ClientUser[]
  contacts  ClientContact[]
  @@index([tenantId, name])
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  email     String?
  telefone  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@index([clientId, createdAt])
}

model ClientUser {
  id       String  @id @default(cuid())
  userId   String
  clientId String
  user     User    @relation("ClientUser", fields: [userId], references: [id], onDelete: Cascade)
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  @@unique([userId, clientId])
  @@index([clientId, userId])
}

enum TipoProjeto {
  INTERNO
  FIXED_PRICE
  AMS
  TIME_MATERIAL
}

model Project {
  id                    String    @id @default(cuid())
  name                  String
  description           String?
  clientId              String
  createdAt             DateTime  @default(now())
  createdById           String
  createdBy             User      @relation("ProjectCreator", fields: [createdById], references: [id])
  client                Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dataInicio            DateTime?
  dataFimPrevista       DateTime?
  prioridade            String?
  totalHorasPlanejadas  Float?
  statusInicial         String    @default("PLANEJADO")
  obrigatoriosHoras     Boolean   @default(false)
  obrigatoriosDataEntrega Boolean @default(false)
  
  // Tipo e configurações do projeto
  tipoProjeto TipoProjeto? @default(INTERNO)

  kanbanColumns KanbanColumn[]
  
  // Configurações Fixed Price
  valorContrato Float?
  escopoInicial String?
  limiteHorasEscopo Float?
  changeRequestsAtivo Boolean? @default(false)
  
  // Configurações AMS
  tipoContratoAMS String? // MENSAL_FIXO, BANCO_HORAS
  horasMensaisAMS Float?
  bancoHorasInicial Float?
  slaAMS Int? // dias
  slaRespostaBaixa Int?
  slaSolucaoBaixa Int?
  slaRespostaMedia Int?
  slaSolucaoMedia Int?
  slaRespostaAlta Int?
  slaSolucaoAlta Int?
  slaRespostaCritica Int?
  slaSolucaoCritica Int?
  
  // Configurações Time & Material
  periodoAprovacaoTM String? // MENSAL, QUINZENAL
  aprovacaoAutomaticaTM Boolean? @default(false)
  estimativaInicialTM Float?
  
  // Anexo de proposta comercial e escopo
  anexoNomeArquivo String?
  anexoUrl String? // URL ou path do arquivo
  anexoTipo String? // application/pdf, application/vnd.openxmlformats-officedocument.wordprocessingml.document
  anexoTamanho Int? // tamanho em bytes
  
  // Status de arquivamento
  arquivado Boolean @default(false)
  arquivadoEm DateTime?
  
  tickets               Ticket[]
  timeEntries           TimeEntry[]
  activities            ActivityProject[]
  responsibles          ProjectResponsible[]
  timeEntryPermissionRequests TimeEntryPermissionRequest[]
  @@index([clientId, arquivado, createdAt])
}

/// Colunas customizadas do Kanban persistidas por projeto (visível para todos os usuários do tenant).
model KanbanColumn {
  /// ID público usado como status nos tickets (ex.: CUSTOM_EM_QA_1712345678901)
  id        String   @id
  tenantId  String
  projectId String
  label     String
  color     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, id], map: "kanban_columns_project_id_uq")
  @@index([tenantId, projectId, deletedAt, order], map: "kanban_columns_tenant_project_idx")
  @@map("kanban_columns")
}

model ProjectResponsible {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation("ProjectResponsible", fields: [userId], references: [id], onDelete: Cascade)
  @@unique([projectId, userId])
  @@index([userId, projectId])
}

model Ticket {
  id              String   @id @default(cuid())
  code            String
  title           String
  description     String?
  type            String
  criticidade     String?
  status          String   @default("ABERTO")
  /** Prioridade manual da fila do consultor (1 = mais prioritária). */
  queuePriority   Int?
  finalizacaoMotivo String?
  finalizacaoObservacao String?
  projectId       String
  parentTicketId  String?  // ID do subprojeto pai (se esta tarefa pertence a um subprojeto)
  createdById     String?
  assignedToId   String?
  dataInicio      DateTime? // Data de início da tarefa
  dataFimPrevista DateTime? // Data de entrega prevista
  estimativaHoras Float?    // Estimativa de horas (número de horas)
  slaRespostaHoras Int?     // SLA de resposta aplicado na criação (AMS)
  slaSolucaoHoras Int?      // SLA de solução aplicado na criação (AMS)
  progresso       Int?      @default(0) // Progresso em porcentagem (0-100)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentTicket    Ticket?  @relation("TicketHierarchy", fields: [parentTicketId], references: [id], onDelete: Cascade)
  childTickets    Ticket[] @relation("TicketHierarchy")
  createdBy       User?    @relation("TicketCreator", fields: [createdById], references: [id])
  assignedTo      User?    @relation("AssignedConsultant", fields: [assignedToId], references: [id])
  timeEntries     TimeEntry[]
  responsibles    TicketResponsible[]
  comments        TicketComment[]
  timeEntryPermissionRequests TimeEntryPermissionRequest[]
  history         TicketHistory[]
  attachments     TicketAttachment[]
  budget          TicketBudget?
  @@index([projectId, createdAt])
  @@index([projectId, status, createdAt])
  @@index([assignedToId])
  @@index([createdById])
  @@index([parentTicketId])
}

model TicketBudget {
  id          String   @id @default(cuid())
  ticketId    String   @unique
  status      String   @default("NENHUM") // NENHUM | AGUARDANDO_APROVACAO | APROVADO | REPROVADO
  horas       Float
  observacao  String
  rejectionReason String?
  sentById    String?
  decidedById String?
  sentAt      DateTime?
  decidedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sentBy      User?    @relation("TicketBudgetSentBy", fields: [sentById], references: [id])
  decidedBy   User?    @relation("TicketBudgetDecidedBy", fields: [decidedById], references: [id])

  @@index([status])
}

model TicketResponsible {
  id       String  @id @default(cuid())
  ticketId String
  userId   String
  ticket   Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([ticketId, userId])
  @@index([userId, ticketId])
}

model Activity {
  id          String      @id @default(cuid())
  name        String
  isActive    Boolean     @default(true)
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]
  projects    ActivityProject[]
  @@index([tenantId, name])
}

model ActivityProject {
  id         String  @id @default(cuid())
  activityId String
  projectId  String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@unique([activityId, projectId])
  @@index([projectId])
  @@index([activityId])
}

model TimeEntry {
  id              String    @id @default(cuid())
  date            DateTime
  horaInicio      String
  horaFim         String
  intervaloInicio String?
  intervaloFim    String?
  totalHoras      Float
  description     String?
  userId          String
  projectId       String
  ticketId        String?
  activityId      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ticket          Ticket?   @relation(fields: [ticketId], references: [id])
  activity        Activity? @relation(fields: [activityId], references: [id])
  @@index([userId, date])
  @@index([projectId, date])
  @@index([ticketId, date, horaInicio])
}

model TicketComment {
  id          String   @id @default(cuid())
  ticketId    String
  userId      String
  content     String   // HTML content do comentário
  visibility  CommentVisibility @default(PUBLIC)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments TicketCommentAttachment[]
  @@index([ticketId, createdAt])
}

enum CommentVisibility {
  PUBLIC
  INTERNAL
}

model TicketHistory {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  action    String   // CREATE, UPDATE, DELETE, STATUS_CHANGE, PRIORITY_CHANGE, ASSIGNED, etc
  field     String?  // Campo alterado (title, description, status, etc) - null para CREATE/DELETE
  oldValue  String?  // Valor anterior (JSON string para objetos complexos)
  newValue  String?  // Valor novo (JSON string para objetos complexos)
  details   String?  // Detalhes adicionais da ação
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation("TicketHistoryUser", fields: [userId], references: [id], onDelete: Cascade)
  @@index([ticketId])
  @@index([createdAt])
}

model TicketCommentAttachment {
  id        String         @id @default(cuid())
  commentId String
  filename  String
  fileUrl   String         // URL ou path do arquivo
  fileType  String         // image/png, image/jpeg, etc
  fileSize  Int            // tamanho em bytes
  createdAt DateTime       @default(now())
  comment   TicketComment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model TicketAttachment {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  filename  String
  fileUrl   String   // URL ou path do arquivo
  fileType  String   // MIME type (image/png, application/pdf, etc)
  fileSize  Int      // tamanho em bytes
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation("TicketAttachmentUser", fields: [userId], references: [id], onDelete: Cascade)
  @@index([ticketId])
}

model TimeEntryPermissionRequest {
  id              String   @id @default(cuid())
  userId          String
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  justification   String
  date            DateTime
  horaInicio      String
  horaFim         String
  intervaloInicio String?
  intervaloFim    String?
  totalHoras      Float
  description     String?
  projectId       String
  ticketId        String?
  activityId      String?
  createdAt       DateTime @default(now())
  reviewedAt      DateTime?
  reviewedById    String?
  rejectionReason String?

  user      User   @relation("TimeEntryPermissionRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ticket    Ticket? @relation(fields: [ticketId], references: [id])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([userId, status, date])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model HourBankRecord {
  id                  String   @id @default(cuid())
  month               Int
  year                Int
  horasPrevistas      Float
  horasTrabalhadas    Float
  horasComplementares Float?
  /// Horas quitadas em pagamento (não acumuladas no banco); reduz o saldo de complementares do mês.
  horasPagas          Float?
  observacao          String?
  userId              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, month, year])
  @@index([userId, year, month])
}

model TenantHoliday {
  id        String   @id @default(cuid())
  tenantId  String
  /** Data civil do feriado (sem horário). */
  date      DateTime @db.Date
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId, date])
  @@map("tenant_holidays")
}

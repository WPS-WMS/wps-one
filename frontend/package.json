{
  "name": "wps-timesheet-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node scripts/firebase-next-export-fix.mjs",
    "start": "next start",
    "deploy": "npm run build && firebase deploy",
    "deploy:qa": "cross-env NEXT_PUBLIC_API_URL=https://wps-one-backend-qa.onrender.com npm run build && firebase deploy --only hosting:qa",
    "deploy:prod": "cross-env NEXT_PUBLIC_API_URL=https://wps-one-backend-production.onrender.com npm run build && firebase deploy --only hosting:prod"
  },
  "dependencies": {
    "dompurify": "^3.4.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^0.563.0",
    "next": "^16.2.4",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}

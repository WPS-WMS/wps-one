{
  "name": "wps-time-sheet",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "dev:api": "cd backend && npm run dev",
    "dev:web": "cd frontend && npm run dev",
    "dev:local": "npm run dev:api & npm run dev:web",
    "servers:start": "cmd /c scripts\\servers.bat start",
    "servers:start:ps1": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start.ps1",
    "servers:stop": "cmd /c scripts\\servers.bat stop",
    "servers:stop:ps1": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop.ps1",
    "servers:restart": "cmd /c scripts\\servers.bat restart",
    "servers:restart:ps1": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restart.ps1",
    "servers:check": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-servers.ps1",
    "create-users": "cd backend && npx tsx scripts/create-users.ts",
    "backend": "cd backend && npm run dev",
    "backend:node": "cd backend && npm run dev:node",
    "load:test:lite": "node scripts/load-test-lite.mjs"
  },
  "dependencies": {
    "@prisma/client": "6.2.0",
    "bcryptjs": "^2.4.3",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-day-picker": "^9.4.3",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "6.2.0",
    "tsx": "^4.19.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
